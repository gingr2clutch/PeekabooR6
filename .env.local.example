# Copy this file to .env.local and fill in real values.

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Cloudflare R2 (S3-compatible)
R2_ACCOUNT_ID=
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_BUCKET=
# Public base URL for the bucket — either the r2.dev dev URL or your custom domain.
# Example: https://pub-abc123.r2.dev  (no trailing slash)
R2_PUBLIC_URL=

# Admin login password (any string you choose)
ADMIN_PASSWORD=
